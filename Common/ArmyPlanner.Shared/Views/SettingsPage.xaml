<Page
    x:Class="ArmyPlanner.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ArmyPlanner.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical">
        <TextBlock
            x:Uid="Settings_Page_Title"
            Style="{StaticResource HeaderTextBlockStyle}"
            Text="~Einstellungen" />

        <Pivot>

            <!--
            <PivotItem x:Uid="SettingsPivot_SystemPivotItem" Header="~System">

            </PivotItem>
            -->

            <PivotItem x:Uid="SettingsPivot_UpdatesPivotItem" Header="~Updates" />

            <PivotItem x:Uid="SettingsPivot_LanguagePivotItem" Header="~Sprache" />

            <PivotItem x:Uid="SettingsPivot_NetworkPivotItem" Header="~Netzwerk" />

        </Pivot>

    </StackPanel>
</Page>
